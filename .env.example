# ── AI 分析引擎（主幹：OpenRouter，備援：NVIDIA）────────────────
# OpenRouter：統一入口，支援 Gemini / Claude / Llama 等所有模型
# 申請：https://openrouter.ai/keys
OPENAI_API_KEY=your_openrouter_api_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# NVIDIA NIM（fallback 備援用）
# 申請：https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here

# ── 任務分層模型設定 ─────────────────────────────────────────────
# 情感分析：高量逐篇，用輕量快速模型省成本
MODEL_SENTIMENT_PROVIDER=openai_compat
MODEL_SENTIMENT_NAME=google/gemini-2.5-flash

# 主題分類：與情感分析共用
MODEL_THEME_PROVIDER=openai_compat
MODEL_THEME_NAME=google/gemini-2.5-flash

# PR 策略：每次只跑少量，用強力模型提升推理品質
MODEL_PR_ADVISOR_PROVIDER=openai_compat
MODEL_PR_ADVISOR_NAME=anthropic/claude-sonnet-4-5

# Fallback：主模型失敗時的備援
MODEL_FALLBACK_PROVIDER=nvidia
MODEL_FALLBACK_NAME=meta/llama-3.3-70b-instruct

# ── Telegram 通知 ────────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── 監控品牌（逗號分隔，留空則監控所有四大品牌）───────────────
MONITOR_KEYWORDS=7-ELEVEN,全家,萊爾富,OK mart

# ── 日報設定 ─────────────────────────────────────────────────────
# 主目標品牌（日報主角，其他品牌歸為競品動態）
PRIMARY_BRAND=7-ELEVEN

# ── 採集設定 ─────────────────────────────────────────────────────
# 每個渠道（Google News / PTT / Dcard）採集的文章上限
FETCH_LIMIT=10

# ── Dcard 雲端 WAF 繞過（固定走 ScraperAPI）──────────────────────
#   https://www.scraperapi.com — 由 ScraperAPI 代打 Dcard
# SCRAPERAPI_KEY=your_scraperapi_key_here
# DCARD_SEARCH_CACHE_MINUTES=30

# Google News 是否在直連 RSS 失敗時改用 ScraperAPI fallback
GOOGLE_NEWS_USE_SCRAPERAPI_FALLBACK=false

# ── 警報閾值 ─────────────────────────────────────────────────────
# 負面情緒強度達到此值時，自動發送 Telegram 警報（0.0～1.0）
ALERT_THRESHOLD=0.7
